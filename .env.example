# AI Interview Platform - Environment Variables
# Copy this file to .env.local and fill in your values

# Deepgram (STT + TTS) - Get free key at console.deepgram.com
DEEPGRAM_API_KEY=

# AI Model (any OpenAI-compatible endpoint)
AI_BASE_URL=https://api.openai.com
AI_API_KEY=
AI_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql://postgres@localhost:5432/ai_interview_platform

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# TTS Provider: "deepgram" (default) or "edge" (free Indian voices)
TTS_PROVIDER=deepgram
# Edge TTS settings (only when TTS_PROVIDER=edge)
EDGE_TTS_VOICE=en-IN-NeerjaNeural
EDGE_TTS_RATE=+10%

# Email (optional - falls back to console logging)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
